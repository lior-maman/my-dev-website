doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title Contact Me | Lior Maman
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
        style.
            body { background-color: #f8f9fa; color: #212529; font-family: sans-serif; }
            .contact-container { max-width: 600px; margin: 80px auto; padding: 40px; background: #ffffff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
            h1 { color: #0d6efd; font-weight: 700; margin-bottom: 10px; }
            .form-control:focus { border-color: #0d6efd; box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15); }
            .btn-primary { background-color: #0d6efd; border: none; padding: 12px; font-weight: 600; border-radius: 8px; transition: all 0.2s; }
            .btn-primary:hover { background-color: #0b5ed7; }
            .alert { display: none; margin-top: 20px; border-radius: 8px; }

    body
        .container
            .contact-container
                h1 Get In Touch
                p.text-muted Feel free to reach out for collaborations or just to say hi!

                hr.my-4

                // הטופס עם חסימת שליחה מובנית למניעת קריסת ה-Fetch
                form#contactForm(onsubmit="return false;")
                    .mb-3
                        label.form-label(for="name") Full Name
                        input#name.form-control.form-control-lg(type="text" placeholder="John Doe", required)

                    .mb-3
                        label.form-label(for="email") Email Address
                        input#email.form-control.form-control-lg(type="email" placeholder="name@example.com", required)

                    .mb-3
                        label.form-label(for="message") Message
                        textarea#message.form-control(rows="5" placeholder="Your message here...", required)

                    button.btn.btn-primary.w-100.btn-lg(type="submit") Send Message

                // אלרטים להצגת סטטוס השליחה
                #successAlert.alert.alert-success(role="alert") Your message has been sent successfully!
                #errorAlert.alert.alert-danger(role="alert") Something went wrong. Please try again.

        script.
            document.getElementById('contactForm').addEventListener('submit', async (e) => {
                // הגנה כפולה לעצירת רענון הדף וביטול ה-Fetch
                e.preventDefault(); 
                e.stopPropagation();

                // הסתרת אלרטים קודמים
                document.getElementById('successAlert').style.display = 'none';
                document.getElementById('errorAlert').style.display = 'none';

                // איסוף הנתונים מהשדות
                const formData = {
                    name: document.getElementById('name').value,
                    email: document.getElementById('email').value,
                    message: document.getElementById('message').value
                };

                try {
                    // שליחת הנתונים ישירות לנתיב ה-API היחסי בשרת שלך
                    const response = await fetch('/api/v1/contact', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(formData)
                    });

                    const result = await response.json();

                    if (response.ok && result.status === 'success') {
                        document.getElementById('successAlert').style.display = 'block';
                        document.getElementById('contactForm').reset(); // איפוס השדות בטופס
                    } else {
                        document.getElementById('errorAlert').style.display = 'block';
                    }
                } catch (error) {
                    console.error('Error sending form:', error);
                    document.getElementById('errorAlert').style.display = 'block';
                }
            });

        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
