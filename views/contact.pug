doctype html
html(lang="en" dir="ltr")
    head
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1, user-scalable=no")
        title Contact Me | Lior Maman

        // Main CSS
        link(rel="stylesheet" href="/assets/css/main.css")

        // Bootstrap & Icons
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
        link(href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet")

        style.
            body { padding-top: 100px; }
            .contact-container { max-width: 600px; margin: 40px auto 80px auto; padding: 40px; background: #ffffff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); color: #333; }
            h1.contact-title { color: #212529; font-weight: 700; margin-bottom: 10px; font-family: 'Oswald', sans-serif; }
            .form-control:focus { border-color: #333; box-shadow: 0 0 0 0.25rem rgba(33, 37, 41, 0.15); }
            .btn-submit { background-color: #212529; color: #fff; border: none; padding: 12px; font-weight: 600; border-radius: 8px; transition: all 0.2s; }
            .btn-submit:hover { background-color: #343a40; color: #fff; }
            .alert { display: none; margin-top: 20px; border-radius: 8px; }

    body.is-preload

        // תפריט הניווט המקורי והמדויק שלך
        nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top
            .container-fluid
                a.navbar-brand.fw-bold(href="/#intro") LM

                button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation")
                    span.navbar-toggler-icon

                #navbarNav.collapse.navbar-collapse.justify-content-center
                    ul.navbar-nav.gap-2
                        li.nav-item
                            a.nav-link.scrolly(href="/#intro") Intro
                        li.nav-item
                            a.nav-link.scrolly(href="/#two") Tech Foundations
                        li.nav-item
                            a.nav-link.scrolly(href="/#one") Projects
                        li.nav-item
                            a.nav-link.scrolly(href="/#three") Tours Project
                        li.nav-item
                            a.nav-link.active(href="/contact") Contact

        #wrapper
            .container
                .contact-container
                    h1.contact-title Get In Touch
                    p.text-muted Feel free to reach out for collaborations or just to say hi!

                    hr.my-4

                    // הטופס המאובטח עם חסימת ה-Abort
                    form#contactForm(onsubmit="return false;")
                        .mb-3
                            label.form-label.fw-bold(for="name") Full Name
                            input#name.form-control.form-control-lg(type="text" placeholder="John Doe", required)

                        .mb-3
                            label.form-label.fw-bold(for="email") Email Address
                            input#email.form-control.form-control-lg(type="email" placeholder="name@example.com", required)

                        .mb-3
                            label.form-label.fw-bold(for="message") Message
                            textarea#message.form-control(rows="5" placeholder="Your message here...", required)

                        button.btn.btn-submit.w-100.btn-lg(type="submit") Send Message

                    // אלרטים
                    #successAlert.alert.alert-success(role="alert") Your message has been sent successfully!
                    #errorAlert.alert.alert-danger(role="alert") Something went wrong. Please try again.

            // Footer Section
            footer#footer.py-5.mt-5(style="background-color: #f8fafc; border-top: 1px solid #e2e8f0;")
                .inner.container.text-center
                    ul.nav.justify-content-center.mb-4
                        li.nav-item
                            a.nav-link.px-3(href="/edit" style="color: #475569; transition: color 0.2s;") Edit
                        li.nav-item
                            a.nav-link.px-3(href="/contact" style="color: #475569; transition: color 0.2s;") Contact
                        li.nav-item
                            a.nav-link.px-3(href="/privacy" style="color: #475569; transition: color 0.2s;") Privacy Policy

                    p.small.mb-0(style="color: #94a3b8; letter-spacing: 0.5px;") &copy; #{new Date().getFullYear()} Lior Maman. All rights reserved.

        // Scripts המקוריים של האתר שלך
        script(src="/assets/js/jquery.min.js")
        script(src="/assets/js/jquery.scrollex.min.js")
        script(src="/assets/js/jquery.scrolly.min.js")
        script(src="/assets/js/browser.min.js")
        script(src="/assets/js/breakpoints.min.js")
        script(src="/assets/js/util.js")
        script(src="/assets/js/main.js")
        script(src="/assets/js/admin.js")
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")

        // לוגיקת ה-Fetch המאובטחת לשליחת המייל
        script.
            document.getElementById('contactForm').addEventListener('submit', async (e) => {
                e.preventDefault(); 
                e.stopPropagation();

                document.getElementById('successAlert').style.display = 'none';
                document.getElementById('errorAlert').style.display = 'none';

                const formData = {
                    name: document.getElementById('name').value,
                    email: document.getElementById('email').value,
                    message: document.getElementById('message').value
                };

                try {
                    const response = await fetch('/api/v1/contact', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(formData)
                    });

                    const result = await response.json();

                    if (response.ok && result.status === 'success') {
                        document.getElementById('successAlert').style.display = 'block';
                        document.getElementById('contactForm').reset();
                    } else {
                        document.getElementById('errorAlert').style.display = 'block';
                    }
                } catch (error) {
                    console.error('Error sending form:', error);
                    document.getElementById('errorAlert').style.display = 'block';
                }
            });