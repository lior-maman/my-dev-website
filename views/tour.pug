doctype html
html(lang="he", dir="rtl")
  head
    meta(charset="utf-8")
    title= `${tour.name} | עולם הטיולים`
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
    style.
      .hero-section { 
        background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/img/tours/#{tour.imageCover}');
        background-size: cover;
        height: 50vh;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
      }

  body
    // Hero Section
    header.hero-section
      .text-center
        h1.display-2.fw-bold= tour.name
        p.lead= `משך הטיול: ${tour.duration} ימים`

    // Main Content
    main.container.my-5
      .row
        .col-md-8
          h2 אודות הטיול
          p.lead= tour.description
        .col-md-4
          .card.shadow-sm
            .card-body
              h4 פרטים טכניים
              ul.list-group.list-group-flush
                li.list-group-item= `קושי: ${tour.difficulty}`
                li.list-group-item= `מחיר: ${tour.price} ₪`
                li.list-group-item= `קבוצה: עד ${tour.maxGroupSize} אנשים`
              button.btn.btn-primary.w-100.mt-3 הזמן עכשיו

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")