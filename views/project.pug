doctype html
html(lang="en" dir="ltr")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title=`${project.name} | Project Showcase`
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    style.
      .hero-section {
        background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/img/projects/#{project.imageCover}');
        background-size: cover;
        background-position: center;
        height: 50vh;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .tag-badge {
        margin-right: 5px; /* Fixed for left-to-right spacing */
      }

  body
    // Hero Section
    header.hero-section
      .text-center
        h1.display-2.fw-bold= project.name
        p.lead= project.summary

    // Main Content
    main.container.my-5
      .row
        // Left Column - About the Project
        .col-md-8
          h2 Project Overview
          p.lead= project.description

          if project.tags && project.tags.length > 0
            h3.mt-4 Technologies Used
            div.mt-2
              each tag in project.tags
                span.badge.bg-secondary.tag-badge= tag

        // Right Column - Sidebar Card
        .col-md-4
          .card.shadow-sm
            .card-body
              h4 Project Details
              ul.list-group.list-group-flush
                if project.price
                  li.list-group-item=`Price: $${project.price}`
                else
                  li.list-group-item Price: Open Source / N/A
                li.list-group-item=`Created: ${new Date(project.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}`

              // Fixed semantic anchor layout with button styling
              a.btn.btn-primary.w-100.mt-3(href=project.link target="_blank") View Live Project ↗

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")