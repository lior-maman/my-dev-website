doctype html
html(lang="he" dir="rtl")
  head
    meta(charset="utf-8")
    title=`${project.name} | „Ґ„Х„Ь„Э „Ф„§„®„Х„Щ„І„Ш„Щ„Э`
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    style.
      .hero-section {
        background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/img/projects/#{project.imageCover}');
        background-size: cover;
        background-position: center;
        height: 50vh;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .tag-badge {
        margin-left: 5px;
      }

  body
    // Hero Section
    header.hero-section
      .text-center
        h1.display-2.fw-bold= project.name
        p.lead= project.summary

    // Main Content
    main.container.my-5
      .row
        // Left Column - About the Project
        .col-md-8
          h2 „Р„Х„У„Х„™ „Ф„§„®„Х„Щ„І„Ш
          p.lead= project.summary

          if project.tags && project.tags.length > 0
            h3.mt-4 „Ш„Ы„†„Х„Ь„Х„Т„Щ„Х„™ „С„§„®„Х„Щ„І„Ш
            div.mt-2
              each tag in project.tags
                span.badge.bg-secondary.tag-badge= tag

        // Right Column - Sidebar Card
        .col-md-4
          .card.shadow-sm
            .card-body
              h4 „§„®„Ш„Щ„Э „Ш„Ы„†„Щ„Щ„Э
              ul.list-group.list-group-flush
                if project.price
                  li.list-group-item=`„Ю„Ч„Щ„®: вВ™${project.price}`
                else
                  li.list-group-item „Ю„Ч„Щ„®: „Ь„Р „®„Ь„Х„Х„†„Ш„Щ
                li.list-group-item „†„Х„¶„® „С„™„Р„®„Щ„Ъ: #{new Date(project.createdAt).toLocaleDateString('he-IL')}

              button.btn.btn-primary.w-100.mt-3
                a(href=`https://financial-dashboard-5g4t.onrender.com/` class="text-white text-decoration-none") „Ф„¶„Т „§„®„Х„Щ„І„Ш

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")