doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1, user-scalable=no")
    title Lior Maman | Full-Stack Developer

    // Main CSS
    link(rel="stylesheet" href="/assets/css/main.css")

    // Bootstrap & Icons
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css")
    link(href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&display=swap" rel="stylesheet")

  body.is-preload


    nav.navbar.navbar-expand-md.navbar-dark.bg-dark.fixed-top
      .container-fluid
        a.navbar-brand.fw-bold(href="#intro") LM

        // הכפתור כעת באותו קו של הלוגו (הם אחים בתוך ה-container)
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation")
          span.navbar-toggler-icon

        // ה-ul כעת מוזח פנימה, מה שאומר שהוא הבן של #navbarNav ויתקפל איתו בנייד
        #navbarNav.collapse.navbar-collapse.justify-content-center
          ul.navbar-nav.gap-2
            li.nav-item
              a.nav-link.scrolly(href="#intro" class=(path === '#intro' ? 'active' : '')) Intro
            li.nav-item
              a.nav-link.scrolly(href="#two" class=(path === '#two' ? 'active' : '')) Tech Foundations
            li.nav-item
              a.nav-link.scrolly(href="#one" class=(path === '#one' ? 'active' : '')) Projects
            li.nav-item
              a.nav-link.scrolly(href="#three" class=(path === '#three' ? 'active' : '')) Tours Project

    #wrapper
      // Intro (מבוסס בוטסטראפ נקי, ללא תלות בתבנית)
      section#intro.container-fluid.d-flex.flex-column.align-items-center.justify-content-center.text-center.min-vh-100.px-3
        div(style="max-width: 750px;")

          h1.main-logo LIOR MAMAN
          br
          p.lead.mb-5(style="color: #475569; line-height: 1.6;") Full-Stack Developer specializing in high-performance web applications, financial analytics, and data-driven systems.
          a.button.scrolly(href="#two") Learn more

      // Two - Tech Foundations
      section#two.wrapper.style3.fade-up
        .inner
          h2 Tech Foundations 
          p Delivering robust, full-stack ecosystems built on the principles of clean architecture.

          .tech-stack
            .tech-box
              i.fab.fa-node-js.tech-icon
              span Node.js
            .tech-box
              i.fas.fa-database.tech-icon
              span MongoDB
            .tech-box
              i.fab.fa-js.tech-icon
              span JavaScript
            .tech-box
              i.fab.fa-python.tech-icon
              span Python
            .tech-box
              i.fab.fa-react.tech-icon
              span React
            .tech-box
              i.fab.fa-html5.tech-icon
              span HTML5
            .tech-box
              i.fab.fa-css3-alt.tech-icon
              span CSS3
            .tech-box
              i.fab.fa-git-alt.tech-icon
              span Git
            .tech-box
              i.fas.fa-server.tech-icon
              span Express
            .tech-box
              i.fas.fa-terminal.tech-icon
              span Command Line

          // שינוי כאן: הוספת מעטפת למרכוז הכפתור
          .text-center.mt-5
            a.button.scrolly(href="#one") See My Projects

      // One - My Projects
      section#one.wrapper.style2.fade-up
        .inner
          h2.major My Projects
          p A curated selection of full-stack applications showcasing my expertise in building scalable, efficient, and user-friendly solutions.

          .row.row-cols-1.row-cols-md-3.g-4.mt-4
            if projects
              each project in projects
                .col
                  .card.h-100.shadow-sm
                    img.card-img-top(src=`/img/projects/${project.imageCover}`, alt=project.name)
                    .card-body
                      h5.card-title.fw-bold(style="color: #333;")= project.name
                      p.card-text(style="color: #555 !important;")= project.summary

                      if project.tags
                        .mt-3.d-flex.flex-wrap.gap-1
                          each tag in project.tags
                            span.badge.bg-secondary.me-1= tag

                    .card-footer.bg-transparent.border-top-0
                      .d-flex.justify-content-between.align-items-center
                        a.btn.btn-outline-primary.btn-sm.w-100(href=`/project/${project.slug}`) View Details

      // Three - Tours Project
      section#three.wrapper.style1.fade-up
        .inner
          h2.major Our Featured Tours
          p Selected full-stack web applications fetch directly from the database ecosystem.

          .row.row-cols-1.row-cols-md-3.g-4.mt-4
            if tours
              each tour in tours
                .col
                  .card.h-100.shadow-sm
                    img.card-img-top(src=`/img/tours/${tour.imageCover}`, alt=tour.name)
                    .card-body
                      h5.card-title.fw-bold(style="color: #333;")= tour.name
                      p.card-text(style="color: #555 !important;")= tour.summary
                    .card-footer.bg-transparent.border-top-0
                      .d-flex.justify-content-between.align-items-center
                        span.badge.bg-success= `$${tour.price}`
                        a.btn.btn-outline-primary.btn-sm(href=`/tour/${tour.slug}`) View Details


      // Footer מעודכן וממורכז
      footer#footer.py-5.mt-5(style="background-color: #f8fafc; border-top: 1px solid #e2e8f0;")
        .inner.container.text-center
          ul.nav.justify-content-center.mb-4
            li.nav-item
              a#admin-login-link.nav-link.px-3(href="/edit" style="color: #475569; transition: color 0.2s;") Edit
            li.nav-item
              a.nav-link.px-3(href="#" style="color: #475569; transition: color 0.2s;") Contact
            li.nav-item
              a.nav-link.px-3(href="#" style="color: #475569; transition: color 0.2s;") Privacy Policy

          p.small.mb-0(style="color: #94a3b8; letter-spacing: 0.5px;") &copy; #{new Date().getFullYear()} Lior Maman. All rights reserved.

    // Scripts
    script(src="/assets/js/jquery.min.js")
    script(src="/assets/js/jquery.scrollex.min.js")
    script(src="/assets/js/jquery.scrolly.min.js")
    script(src="/assets/js/browser.min.js")
    script(src="/assets/js/breakpoints.min.js")
    script(src="/assets/js/util.js")
    script(src="/assets/js/main.js")
    script(src="/assets/js/admin.js")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")