extends layout

block content

  // Hero
  section.hero#intro

    .hero-content

      span.hero-eyebrow Portfolio + Live Projects

      h1.hero-title
        | Designing how people learn.
        br
        span.hero-title-gradient Building the systems behind it.

      p.hero-description
        | Instructional Designer • Full Stack Developer • AI Builder

      .hero-actions
        a.btn-modern.btn-primary-modern.btn-glow(href="#projects")
          i.bi.bi-grid
          span Explore Projects

        a.btn-modern.btn-secondary-modern(href="#contact")
          i.bi.bi-envelope
          span Contact

      .hero-tech
        span Node.js
        span MongoDB
        span Express
        span React
        span AI
        span Learning Design

    .scroll-indicator
      i.bi.bi-arrow-down

  // About
  section.section
    .container-modern

      .surface.p-5.text-center

        h2.mb-4 About

        p.mx-auto(style="max-width:800px")
          | I design learning experiences and build the systems that support them.
          | My work combines instructional design, software development,
          | data-driven thinking and modern web technologies.

  // Tech Stack
  section.section#tech

    .container-modern

      h2.text-center.mb-5 Tech Stack

      .row.g-4

        .col-md-4
          .card-modern
            .card-modern-body.text-center
              i.bi.bi-cpu.fs-1.mb-3
              h3.card-modern-title Backend
              p.card-modern-description
                | Node.js, Express, REST APIs,
                | MongoDB and server-side architecture.

        .col-md-4
          .card-modern
            .card-modern-body.text-center
              i.bi.bi-window.fs-1.mb-3
              h3.card-modern-title Frontend
              p.card-modern-description
                | HTML5, CSS3, Bootstrap,
                | Pug and responsive interfaces.

        .col-md-4
          .card-modern
            .card-modern-body.text-center
              i.bi.bi-robot.fs-1.mb-3
              h3.card-modern-title AI & Learning
              p.card-modern-description
                | Instructional design,
                | learning systems and AI-powered workflows.

  // Projects
  section.section#projects

    .container-modern

      h2.text-center.mb-3 Featured Projects

      p.text-center.text-muted-modern.mb-5
        | Real applications built with modern web technologies.

      .row.g-4

        if projects
          each project in projects

            .col-lg-4.col-md-6

              .card-modern.h-100

                img(
                  src=`/img/projects/${project.imageCover}`
                  alt=project.name
                )

                .card-modern-body

                  h3.card-modern-title= project.name

                  p.card-modern-description= project.summary

                  if project.tags
                    .card-tags
                      each tag in project.tags
                        span.card-tag= tag

                .card-modern-footer

                  a.btn-modern.btn-outline-modern.w-100(
                    href=`/project/${project.slug}`
                  )
                    span View Project

  // Tours Project
  section.section#tours

    .container-modern

      h2.text-center.mb-3 Live Database Project

      p.text-center.text-muted-modern.mb-5
        | Dynamic content delivered directly from MongoDB.

      .row.g-4

        if tours
          each tour in tours

            .col-lg-4.col-md-6

              .card-modern.h-100

                img(
                  src=`/img/tours/${tour.imageCover}`
                  alt=tour.name
                )

                .card-modern-body

                  h3.card-modern-title= tour.name

                  p.card-modern-description= tour.summary

                .card-modern-footer

                  .d-flex.justify-content-between.align-items-center

                    span.card-tag
                      | $#{tour.price}

                    a.btn-modern.btn-outline-modern(
                      href=`/tour/${tour.slug}`
                    )
                      span Details
  // Contact
  section.section#contact

    .container-modern

      .surface.p-5

        h2.text-center.mb-3 Get In Touch

        p.text-center.text-muted-modern.mb-5
          | Feel free to reach out for collaborations,
          | consulting opportunities or full-time roles.

        form#contactForm

          .mb-3
            label.form-label(for="name") Full Name
            input#name.form-control.form-control-lg(
              type="text"
              placeholder="John Doe"
              required
            )

          .mb-3
            label.form-label(for="email") Email Address
            input#email.form-control.form-control-lg(
              type="email"
              placeholder="name@example.com"
              required
            )

          .mb-3
            label.form-label(for="message") Message
            textarea#message.form-control(
              rows="5"
              placeholder="Tell me about your project..."
              required
            )

          .text-center.mt-4
            button.btn-modern.btn-primary-modern(
              type="submit"
            )
              i.bi.bi-send
              span Send Message

        #successAlert.alert.alert-success.mt-4(
          role="alert"
          style="display:none;"
        )
          | Your message has been sent successfully!

        #errorAlert.alert.alert-danger.mt-4(
          role="alert"
          style="display:none;"
        )
          | Something went wrong. Please try again.


block scripts

  script.

    async function sendContactForm(event) {

      event.preventDefault();

      document.getElementById('successAlert').style.display = 'none';
      document.getElementById('errorAlert').style.display = 'none';

      const formData = {
        name: document.getElementById('name').value,
        email: document.getElementById('email').value,
        message: document.getElementById('message').value
      };

      try {

        const response = await fetch('/api/v1/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(formData)
        });

        const result = await response.json();

        if (response.ok && result.status === 'success') {

          document.getElementById('successAlert').style.display = 'block';
          document.getElementById('contactForm').reset();

        } else {

          document.getElementById('errorAlert').style.display = 'block';
        }

      } catch (error) {

        console.error(error);

        document.getElementById('errorAlert').style.display = 'block';
      }
    }

    document.addEventListener('DOMContentLoaded', () => {

      const form = document.getElementById('contactForm');

      if (!form) return;

      form.addEventListener('submit', sendContactForm);
    });