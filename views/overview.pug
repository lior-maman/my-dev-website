extends layout

block content

  // Hero
  section.hero#intro

    .hero-content

      span.hero-eyebrow Portfolio + Live Projects

      h1.hero-title
        | Designing how people learn.
        br
        span.hero-title-gradient Building the systems behind it.

      p.hero-description
        | Instructional Designer • Full Stack Developer • AI Builder

      .hero-actions
        a.btn-modern.btn-primary-modern.btn-glow(href="#projects")
          i.bi.bi-grid
          span Explore Platform

        a.btn-modern.btn-secondary-modern(href="#contact")
          i.bi.bi-envelope
          span Contact

      .hero-tech
        span Node.js
        span MongoDB
        span Express
        span Mongoose 
        span Artificial intelligence
        span Learning Design

    .scroll-indicator
      i.bi.bi-arrow-down


  // Projects
  section.section#projects

    .container-modern

      h2.text-center.mb-3 Financial Intelligence Platform

      p.text-center.text-muted-modern.mb-5
        | Real applications built with modern web technologies.

      .row.g-4

        if projects
          each project in projects

            .col-lg-4.col-md-6

              .card-modern.h-100

                img(
                  src=`/img/projects/${project.imageCover}`
                  alt=project.name
                )

                .card-modern-body

                  h3.card-modern-title= project.name

                  p.card-modern-description= project.summary

                  if project.tags
                    .card-tags
                      each tag in project.tags
                        span.card-tag= tag

                .card-modern-footer

                  a.btn-modern.btn-outline-modern.w-100(
                    href=`/project/${project.slug}`
                  )
                    span View Project

  // Tours Project
  section.section#tours

    .container-modern

      h2.text-center.mb-3 Live Database Project

      p.text-center.text-muted-modern.mb-5
        | Dynamic content delivered directly from MongoDB.

      .row.g-4

        if tours
          each tour in tours

            .col-lg-4.col-md-6

              .card-modern.h-100

                img(
                  src=`/img/tours/${tour.imageCover}`
                  alt=tour.name
                )

                .card-modern-body

                  h3.card-modern-title= tour.name

                  p.card-modern-description= tour.summary

                .card-modern-footer

                  .d-flex.justify-content-between.align-items-center

                    span.card-tag
                      | $#{tour.price}

                    a.btn-modern.btn-outline-modern(
                      href=`/tour/${tour.slug}`
                    )
                      span Details


  // Tech Stack
  section.section#tech

    .container-modern

      h2.text-center.mb-5 Tech Stack

      .row.g-4

        .col-md-4
          .card-modern
            .card-modern-body.text-center
              i.bi.bi-cpu.fs-1.mb-3
              h3.card-modern-title Backend
              p.card-modern-description
                | Node.js, Express, REST APIs,
                | MongoDB and server-side architecture.

        .col-md-4
          .card-modern
            .card-modern-body.text-center
              i.bi.bi-window.fs-1.mb-3
              h3.card-modern-title Frontend
              p.card-modern-description
                | HTML5, CSS3, Bootstrap,
                | Pug and responsive interfaces.

        .col-md-4
          .card-modern
            .card-modern-body.text-center
              i.bi.bi-robot.fs-1.mb-3
              h3.card-modern-title AI & Learning
              p.card-modern-description
                | Instructional design,
                | learning systems and AI-powered workflows.


block scripts

  script.

    async function sendContactForm(event) {

      event.preventDefault();

      document.getElementById('successAlert').style.display = 'none';
      document.getElementById('errorAlert').style.display = 'none';

      const formData = {
        name: document.getElementById('name').value,
        email: document.getElementById('email').value,
        message: document.getElementById('message').value
      };

      try {

        const response = await fetch('/api/v1/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(formData)
        });

        const result = await response.json();

        if (response.ok && result.status === 'success') {

          document.getElementById('successAlert').style.display = 'block';
          document.getElementById('contactForm').reset();

        } else {

          document.getElementById('errorAlert').style.display = 'block';
        }

      } catch (error) {

        console.error(error);

        document.getElementById('errorAlert').style.display = 'block';
      }
    }

    document.addEventListener('DOMContentLoaded', () => {

      const form = document.getElementById('contactForm');

      if (!form) return;

      form.addEventListener('submit', sendContactForm);
    });